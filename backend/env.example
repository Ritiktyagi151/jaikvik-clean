# Server Configuration
NODE_ENV=development
PORT=5002
HOST=localhost

# MongoDB Configuration
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.mongodb.net/your_db

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=30d

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@yourapp.com
MAIL_TO=info@jaikvik.com
HR_EMAIL_USER=hr@jaikviktechnology.com
HR_EMAIL_PASS=your_hr_app_password
HR_MAIL_TO=hr@jaikviktechnology.com
ADMIN_NOTIFICATION_EMAIL=admin@yourapp.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@yourapp.com
SMTP_ALLOW_SELF_SIGNED=false

# Google Calendar Meeting Configuration
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_CLIENT_EMAIL=service-account@project-id.iam.gserviceaccount.com
GOOGLE_CALENDAR_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_IMPERSONATED_USER=
MEETING_TIME_ZONE=Asia/Kolkata
MEETING_DURATION_MINUTES=30
REQUIRE_MEETING_SCHEDULING=false
DEFAULT_FALLBACK_MEETING_LINK=https://meet.google.com/new

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_here
